<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>家計簿</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body {
      margin: 0;
      padding: 24px;
      font-family: 'Inter', 'Segoe UI', sans-serif;
      background-color: #e5e7eb;
      color: #333;
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 12px;
      background: white;
      border-radius: 8px;
      margin-bottom: 10px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
    }

    .delete-transaction {
      background: #ef4444;
      color: white;
      border: none;
      border-radius: 6px;
      padding: 6px 10px;
      cursor: pointer;
    }

    .delete-transaction:hover {
      background: #dc2626;
    }

    form {
      max-width: 760px;
      margin-bottom: 24px;
    }

    .form-row {
      display: flex;
      align-items: flex-end;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .form-group {
      flex: 1;
      min-width: 180px;
    }

    .full-width {
      flex: 1 1 100%;
    }

    input {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      font-size: 14px;
      box-sizing: border-box;
    }

    .submit-button {
      background: #3b82f6;
      color: white;
      border: none;
      border-radius: 8px;
      padding: 12px 18px;
      cursor: pointer;
      min-width: 120px;
      align-self: flex-end;
    }

    .submit-button:hover {
      background: #2563eb;
    }

    .chart-section {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
      margin-top: 24px;
    }

    .chart-card {
      background: white;
      border-radius: 12px;
      padding: 16px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
    }

    .chart-card h3 {
      margin-top: 0;
      margin-bottom: 12px;
    }

    .legend {
      margin-top: 12px;
      padding: 0;
      list-style: none;
    }

    .legend li {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 8px;
      padding: 4px 0;
      background: transparent;
      box-shadow: none;
      margin-bottom: 0;
    }

    .swatch {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      display: inline-block;
    }

    .suggestion-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .suggestion-button {
      border: 1px solid #cbd5e1;
      background: white;
      color: #334155;
      border-radius: 999px;
      padding: 6px 10px;
      cursor: pointer;
      font-size: 13px;
    }

    .suggestion-button:hover {
      background: #eff6ff;
      border-color: #60a5fa;
    }

    .suggestion-button.active {
      background: #eff6ff;
      border-color: #60a5fa;
      color: #1d4ed8;
      box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.2);
    }

    .type-toggle {
      display: inline-flex;
      gap: 8px;
      margin-top: 4px;
    }

    .type-toggle-button {
      border: 1px solid #cbd5e1;
      background: white;
      color: #334155;
      border-radius: 999px;
      padding: 6px 10px;
      cursor: pointer;
      font-size: 13px;
    }

    .type-toggle-button.active {
      background: #dbeafe;
      border-color: #60a5fa;
      color: #1d4ed8;
    }
  </style>
</head>
<body>
  <h1>家計簿</h1>

  <form action="/transactions" method="post">
    <div class="form-row">
      <div class="form-group full-width">
        <label>項目名</label><br />
        <div class="suggestion-buttons" role="group" aria-label="項目名">
          <button type="button" class="suggestion-button" data-value="食費">食費</button>
          <button type="button" class="suggestion-button" data-value="生活用品">生活用品</button>
          <button type="button" class="suggestion-button" data-value="交通費">交通費</button>
          <button type="button" class="suggestion-button" data-value="娯楽">娯楽</button>
          <button type="button" class="suggestion-button" data-value="収入">収入</button>
          <button type="button" class="suggestion-button" data-value="その他">その他</button>
        </div>
        <input type="hidden" name="title" id="selectedTitle" value="" />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="amount">金額</label><br />
        <input id="amount" type="number" name="amount" min="0" placeholder="金額（例: 1000）" />
      </div>
      <div class="form-group">
        <label>種別</label><br />
        <div class="type-toggle">
          <button type="button" class="type-toggle-button active" data-entry-type="expense">支出</button>
          <button type="button" class="type-toggle-button" data-entry-type="income">収入</button>
        </div>
        <input type="hidden" name="entryType" id="entryType" value="expense" />
      </div>
      <button type="submit" class="submit-button">追加</button>
    </div>
  </form>

  <hr />

  <h2>所持金: <span id="totalAmount"><%= totalAmount.toLocaleString() %></span> 円</h2>

  <h3>利用履歴</h3>
  <ul>
    <% transactions.forEach((item) => { %>
      <li>
        <span>種別: <strong><%= item.type %></strong> / 項目: <strong><%= item.title %></strong> / 金額: <%= item.displayAmount.toLocaleString() %> 円</span>
        <button type="button" class="delete-transaction" data-id="<%= item.id %>">取り消し</button>
      </li>
    <% }) %>
  </ul>

  <div class="chart-section">
    <div class="chart-card">
      <h3>支出の円グラフ</h3>
      <% const expenseTotal = expenseChartData.reduce((sum, item) => sum + item.value, 0); %>
      <% let expenseStartAngle = -90; %>
      <svg viewBox="0 0 220 220" width="220" height="220" role="img" aria-label="支出の円グラフ">
        <circle cx="110" cy="110" r="80" fill="none" stroke="#e5e7eb" stroke-width="40"></circle>
        <% expenseChartData.forEach((item) => { %>
          <% const ratio = expenseTotal > 0 ? item.value / expenseTotal : 0; %>
          <% const endAngle = expenseStartAngle + ratio * 360; %>
          <% const startX = 110 + 80 * Math.cos((expenseStartAngle - 90) * Math.PI / 180); %>
          <% const startY = 110 + 80 * Math.sin((expenseStartAngle - 90) * Math.PI / 180); %>
          <% const endX = 110 + 80 * Math.cos((endAngle - 90) * Math.PI / 180); %>
          <% const endY = 110 + 80 * Math.sin((endAngle - 90) * Math.PI / 180); %>
          <% const largeArcFlag = ratio > 0.5 ? 1 : 0; %>
          <path d="M 110 110 L <%= startX %> <%= startY %> A 80 80 0 <%= largeArcFlag %> 1 <%= endX %> <%= endY %> Z" fill="<%= item.color %>"></path>
          <% expenseStartAngle = endAngle; %>
        <% }) %>
      </svg>
      <ul class="legend">
        <% expenseChartData.forEach((item) => { %>
          <li><span class="swatch" style="background-color:<%= item.color %>"></span><%= item.label %></li>
        <% }) %>
      </ul>
    </div>
  </div>

  <script>
    const selectedTitleInput = document.getElementById('selectedTitle');
    const entryTypeInput = document.getElementById('entryType');
    const categoryButtons = document.querySelectorAll('.suggestion-button');
    const typeButtons = document.querySelectorAll('.type-toggle-button');

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        categoryButtons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        if (selectedTitleInput) {
          selectedTitleInput.value = button.dataset.value || '';
        }
      });
    });

    typeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        typeButtons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        if (entryTypeInput) {
          entryTypeInput.value = button.dataset.entryType || 'expense';
        }
      });
    });

    async function deleteTransaction(event) {
      const button = event.currentTarget;
      const id = button.dataset.id;
      if (!id) {
        return;
      }

      try {
        const formBody = new URLSearchParams();
        formBody.append('id', id);

        const response = await fetch('/transactions/delete', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'Accept': 'application/json',
          },
          body: formBody.toString(),
        });

        if (!response.ok) {
          throw new Error('取り消しに失敗しました');
        }

        const result = await response.json();
        if (!result.success) {
          throw new Error('取り消しに失敗しました');
        }

        const listItem = button.closest('li');
        if (listItem) {
          listItem.remove();
        }

        const totalAmount = document.getElementById('totalAmount');
        if (totalAmount) {
          totalAmount.textContent = Number(result.totalAmount).toLocaleString();
        }
      } catch (error) {
        alert('取り消しに失敗しました');
      }
    }

    document.querySelectorAll('.delete-transaction').forEach((button) => {
      button.addEventListener('click', deleteTransaction);
    });
  </script>
</body>
</html>